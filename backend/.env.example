FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=mysql+pymysql://root:password@127.0.0.1:3306/cleaning_platform?charset=utf8mb4
APP_TIMEZONE=Asia/Shanghai

# 后台每 7 分钟把前天、昨天、今天的订单同步到 MySQL。
WDT_SYNC_ENABLED=true
WDT_SYNC_ON_STARTUP=true
WDT_SYNC_INTERVAL_SECONDS=420
WDT_SYNC_TIME_TYPE=1
WDT_SYNC_PAGE_SIZE=500
WDT_SYNC_OVERLAP_MINUTES=15
WDT_SHOP_OWNER_CACHE_SECONDS=30
WDT_WINDOW_HOURS=6

# Optional local profit workbook directory. Leave empty when only using WDT orders.
PROFIT_DATA_DIR=

# WDT OpenAPI config. Copy this file to .env and fill real values.
WDT_SID=your_sid
WDT_APPKEY=your_appkey
WDT_APPSECRET=your_appsecret
WDT_API_URL=https://openapi.huice.com/openapi/trade_query.php

# Seconds to wait between page requests, useful for avoiding rate limits.
WDT_PAGE_DELAY=0.4
WDT_HTTP_TIMEOUT_SECONDS=240
WDT_RATE_LIMIT_RETRIES=4

# Default page safety limit. 0 means unlimited and follows the API total_count.
WDT_MAX_PAGES=0
